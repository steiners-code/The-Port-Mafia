generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["main"]
}

model connectedApps {
  id String @id @default(uuid())

  userId String
  app    APPTYPE
  status APPSTATUS

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, app])
  @@schema("main")
}

enum APPTYPE {
  LINKEDIN
  X
  REDDIT
  FACEBOOK
  INSTAGRAM
  THREADS
  TIKTOK

  @@schema("main")
}

enum APPSTATUS {
  CONNECTED
  DISCONNECTED

  @@schema("main")
}
