generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["main"]
}

model Session {
  id String @id @default(uuid())

  userId    String
  userAgent String?
  ipAddress String?
  isRevoked Boolean @default(false)

  tokens RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("main")
}

model RefreshToken {
  id String @id @default(uuid())

  hash      String  @unique
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  isUsed    Boolean @default(false)

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@schema("main")
}

model connectedApps {
  id String @id @default(uuid())

  userId String
  app    APPTYPE
  status APPSTATUS

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, app])
  @@schema("main")
}

enum APPTYPE {
  LINKEDIN
  X
  REDDIT
  FACEBOOK
  INSTAGRAM
  THREADS
  TIKTOK

  @@schema("main")
}

enum APPSTATUS {
  CONNECTED
  DISCONNECTED

  @@schema("main")
}
